# Optional toggles
# MMX_IMAGE_ANALYSIS_ENABLED=true
# MMX_IMAGE_ANALYSIS_LIMIT=30
# MMX_IMAGE_ANALYSIS_RETRIES=2
# MMX_IMAGE_ANALYSIS_TIMEOUT_MS=120000
# ENABLE_SCHEDULED_ANALYSIS=false
# SCHEDULED_ANALYSIS_TIME=0 0 8 * * *
# PORT=3000
